<div class="page-shell page-shell--calendar">
  <section class="surface-panel calendar-shell">
    <div class="calendar-toolbar">
      <div class="calendar-toolbar__nav">
        <div class="calendar-week-switcher">
          <%= link_to "‹", calendar_path(week_offset: @week_offset - 1, platform: (@selected_platform unless @selected_platform == "all")), class: "calendar-nav-button" %>

          <div>
            <span class="eyebrow">Calendar</span>
            <h1 class="section-title" style="font-size: clamp(1.7rem, 4vw, 2.5rem); max-width: none;"><%= @week_range_label %></h1>
          </div>

          <%= link_to "›", calendar_path(week_offset: @week_offset + 1, platform: (@selected_platform unless @selected_platform == "all")), class: "calendar-nav-button" %>
        </div>
      </div>

      <div class="calendar-toolbar__actions">
        <div class="calendar-filter-group">
          <% @available_platform_filters.each do |platform| %>
            <% active = @selected_platform == platform %>
            <% path = platform == "all" ? calendar_path(week_offset: @week_offset) : calendar_path(week_offset: @week_offset, platform: platform) %>
            <%= link_to path, class: "calendar-filter #{'calendar-filter--active' if active}" do %>
              <%= platform == "all" ? "All platforms" : platform_display_name(platform) %>
            <% end %>
          <% end %>
        </div>

        <div class="dashboard-inline-actions">
          <%= link_to "Open planification", planification_path, class: "button-ghost button-ghost--sm" %>
          <%= link_to "Settings", settings_path(anchor: "platforms"), class: "button-primary button-primary--sm" %>
        </div>
      </div>
    </div>

    <div class="calendar-context-grid">
      <div class="mini-panel">
        <span class="mini-panel__label">Guided by</span>
        <% if @active_plan.present? %>
          <strong class="mini-panel__title"><%= @active_plan.title %></strong>
          <p><%= @active_plan.objective.presence || @active_plan.message_angle.presence || "Refine the campaign goal in Planification." %></p>
        <% else %>
          <strong class="mini-panel__title">No active campaign</strong>
          <p>Create or activate a plan so the weekly board follows a larger system.</p>
        <% end %>
      </div>

      <div class="mini-panel">
        <span class="mini-panel__label">This week</span>
        <strong class="mini-panel__title"><%= pluralize(@week_post_count, "post") %></strong>
        <p><%= @week_pending_count %> pending review and <%= @week_approved_count %> already approved for publishing flow.</p>
      </div>

      <div class="mini-panel">
        <span class="mini-panel__label">Next phase</span>
        <% if @next_plan.present? %>
          <strong class="mini-panel__title"><%= @next_plan.title %></strong>
          <p>Starts <%= @next_plan.start_on.strftime("%b %-d") %>. Keep the board warm for the transition.</p>
        <% else %>
          <strong class="mini-panel__title">Nothing queued</strong>
          <p>Use Planification to sequence the next campaign after this one.</p>
        <% end %>
      </div>
    </div>

    <div class="calendar-board-wrap">
      <div class="calendar-board">
        <% @calendar_days.each do |day| %>
          <section class="calendar-column <%= 'calendar-column--today' if day.date == Time.zone.today %>">
            <header class="calendar-column__header">
              <div class="calendar-column__date">
                <span class="calendar-column__day-number"><%= day.date.day %></span>
                <div>
                  <strong><%= day.label.upcase %></strong>
                  <p><%= pluralize(day.drafts.count, "post") %></p>
                </div>
              </div>
            </header>

            <div class="calendar-column__cards">
              <% if day.drafts.any? %>
                <% day.drafts.each do |draft| %>
                  <% draft_platforms = calendar_draft_platforms(draft, preferred_platforms: @preferred_platforms) %>
                  <%= link_to content_draft_path(draft), class: calendar_draft_card_class(draft, preferred_platforms: @preferred_platforms) do %>
                    <div class="calendar-post-card__meta">
                      <span><%= draft.created_at.strftime("%l:%M %p").strip %></span>
                      <span class="<%= draft_status_badge_class(draft.status) %>"><%= calendar_draft_status_label(draft) %></span>
                    </div>

                    <div class="calendar-post-card__platforms">
                      <% if draft_platforms.any? %>
                        <% draft_platforms.each do |platform| %>
                          <span class="<%= platform_badge_class(platform) %>"><%= platform_short_name(platform) %></span>
                        <% end %>
                      <% else %>
                        <span class="platform-badge platform-badge--neutral">TBD</span>
                      <% end %>
                    </div>

                    <h3 class="calendar-post-card__title"><%= calendar_draft_title(draft) %></h3>
                    <p class="calendar-post-card__excerpt"><%= calendar_draft_excerpt(draft) %></p>
                  <% end %>
                <% end %>
              <% else %>
                <div class="calendar-empty-slot">
                  <span class="calendar-empty-slot__label">Open slot</span>
                  <p><%= @active_plan.present? ? "Use this space for #{@active_plan.title.downcase}." : "No post planned yet." %></p>
                </div>
              <% end %>
            </div>
          </section>
        <% end %>
      </div>
    </div>
  </section>
</div>
