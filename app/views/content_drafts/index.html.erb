<div class="page-shell">
  <section class="page-hero">
    <div class="surface-panel surface-panel--accent page-hero__content">
      <span class="eyebrow">Draft archive</span>
      <h1 class="page-title">A running record of moments worth publishing.</h1>
      <p class="section-copy section-copy--lead">
        Everything here started as something real: a launch, a lesson, a client win, a thought worth catching before it disappeared.
      </p>
    </div>

    <div class="surface-panel page-hero__aside">
      <span class="eyebrow">Volume</span>
      <h2 class="page-title" style="font-size: 2.8rem;"><%= @drafts.count %></h2>
      <p class="section-copy">Drafts currently stored in your Ayla workflow.</p>
    </div>
  </section>

  <% if @drafts.any? %>
    <div class="timeline-list">
      <% @drafts.each do |draft| %>
        <%= link_to content_draft_path(draft), class: "list-card" do %>
          <div class="list-card__meta">
            <span>
              <%= draft.created_at.strftime("%b %d, %Y at %l:%M %p") %>
              <% if draft.platform.present? %>
                · <%= draft.platform.titleize %>
              <% end %>
            </span>
            <span class="<%= draft_status_badge_class(draft.status) %>"><%= draft.status.titleize %></span>
          </div>

          <h2 class="list-card__title"><%= truncate(draft.body, length: 180) %></h2>
          <p class="section-copy">Open the full draft to review the text and status details.</p>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="empty-card">
      <h2 class="list-card__title">No drafts yet.</h2>
      <p>Start a Telegram conversation with Ayla and let your first real moment become something publishable.</p>
    </div>
  <% end %>
</div>
