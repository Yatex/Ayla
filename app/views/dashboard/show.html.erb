<div class="page-shell">
  <section class="page-hero">
    <div class="surface-panel page-hero__content">
      <span class="eyebrow">Overview</span>
      <h1 class="page-title">Content operations, not another hero banner.</h1>
      <p class="section-copy section-copy--lead">
        See what needs attention now: queue, connection state, next actions, and whether your posting rhythm is actually holding.
      </p>
    </div>

    <div class="surface-panel surface-panel--soft page-hero__aside">
      <span class="eyebrow">Current status</span>
      <h2 class="section-title" style="font-size: clamp(1.6rem, 4vw, 2.4rem); max-width: none;"><%= @workspace_status[:label] %></h2>
      <p class="section-copy"><%= @workspace_status[:detail] %></p>
    </div>
  </section>

  <section class="metrics-grid">
    <article class="metric-card">
      <span class="metric-card__label">Pending drafts</span>
      <h2 class="metric-card__value"><%= @pending_count %></h2>
      <p class="metric-card__hint">Drafts currently waiting for your approval.</p>
    </article>

    <article class="metric-card">
      <span class="metric-card__label">Approval rate</span>
      <h2 class="metric-card__value"><%= @approval_rate %>%</h2>
      <p class="metric-card__hint">Approved versus rejected across reviewed drafts.</p>
    </article>

    <article class="metric-card">
      <span class="metric-card__label">Telegram</span>
      <h2 class="metric-card__value"><%= @telegram_connected ? "Live" : "Offline" %></h2>
      <p class="metric-card__hint"><%= @telegram_connected ? "Ayla can prompt and collect moments in chat." : "Link Telegram to activate the assistant workflow." %></p>
    </article>

    <article class="metric-card">
      <span class="metric-card__label">Drafts this week</span>
      <h2 class="metric-card__value"><%= @drafts_this_week %></h2>
      <p class="metric-card__hint">A simple signal for whether the publishing rhythm is warm or fading.</p>
    </article>
  </section>

  <section class="dashboard-layout">
    <div class="stack">
      <div class="surface-panel">
        <div class="section-header">
          <span class="eyebrow">Approval queue</span>
          <h2 class="section-title" style="font-size: clamp(1.55rem, 4vw, 2.25rem); max-width: none;">What needs your decision now.</h2>
        </div>

        <% if @approval_queue.any? %>
          <div class="timeline-list">
            <% @approval_queue.each do |draft| %>
              <%= link_to content_draft_path(draft), class: "list-card" do %>
                <div class="list-card__meta">
                  <span>Waiting since <%= time_ago_in_words(draft.created_at) %> ago</span>
                  <span class="<%= draft_status_badge_class(draft.status) %>"><%= draft.status.titleize %></span>
                </div>
                <h3 class="list-card__title"><%= truncate(draft.body, length: 150) %></h3>
                <p class="section-copy">Review it now to keep the queue moving and the workflow clean.</p>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <div class="empty-card">
            <h3 class="list-card__title">Approval queue is clear.</h3>
            <p>You have room to capture something fresh without any backlog slowing Ayla down.</p>
          </div>
        <% end %>
      </div>

      <div class="surface-panel">
        <div class="section-header">
          <span class="eyebrow">Recent activity</span>
          <h2 class="section-title" style="font-size: clamp(1.55rem, 4vw, 2.25rem); max-width: none;">Latest movement in your workflow.</h2>
        </div>

        <% if @recent_activity.any? %>
          <div class="timeline-list">
            <% @recent_activity.each do |draft| %>
              <%= link_to content_draft_path(draft), class: "list-card" do %>
                <div class="list-card__meta">
                  <span><%= draft.created_at.strftime("%b %d · %l:%M %p") %></span>
                  <span class="<%= draft_status_badge_class(draft.status) %>"><%= draft.status.titleize %></span>
                </div>
                <h3 class="list-card__title"><%= truncate(draft.body, length: 130) %></h3>
                <p class="section-copy">Ayla turned a real moment into this draft and moved it into your working system.</p>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <div class="empty-card">
            <h3 class="list-card__title">No recent activity yet.</h3>
            <p>Connect Telegram, capture a real moment, and let Ayla start building your operational queue.</p>
          </div>
        <% end %>
      </div>
    </div>

    <div class="stack">
      <div class="surface-panel surface-panel--accent">
        <div class="section-header">
          <span class="eyebrow">Upcoming reminders</span>
          <h2 class="section-title" style="font-size: clamp(1.45rem, 4vw, 2.1rem); max-width: none;">The next actions keeping you visible.</h2>
        </div>

        <div class="task-list">
          <% @upcoming_tasks.each do |task| %>
            <% task_path = workspace_task_path(task, telegram_connect_url: @telegram_connect_url) %>
            <% external = workspace_task_external?(task, telegram_connect_url: @telegram_connect_url) %>
            <%= link_to task_path,
                class: workspace_task_classes(task),
                target: (external ? "_blank" : nil),
                rel: (external ? "noopener" : nil) do %>
              <div class="task-card__header">
                <span class="task-card__due"><%= task.due_label %></span>
              </div>
              <h3><%= task.title %></h3>
              <p><%= task.detail %></p>
            <% end %>
          <% end %>
        </div>
      </div>

      <div class="surface-panel">
        <div class="section-header">
          <span class="eyebrow">Posting rhythm</span>
          <h2 class="section-title" style="font-size: clamp(1.45rem, 4vw, 2.1rem); max-width: none;">How the last 7 days actually looked.</h2>
          <p class="section-copy">Not vanity metrics. Just whether the system stayed warm.</p>
        </div>

        <% max_rhythm = [@posting_rhythm.map(&:count).max.to_i, 1].max %>
        <div class="rhythm-bars">
          <% @posting_rhythm.each do |point| %>
            <% fill_height = point.count.zero? ? 12 : [((point.count.to_f / max_rhythm) * 100).round, 18].max %>
            <div class="rhythm-bar">
              <span class="rhythm-bar__count"><%= point.count %></span>
              <div class="rhythm-bar__track">
                <div class="rhythm-bar__fill" style="height: <%= fill_height %>%;"></div>
              </div>
              <span class="rhythm-bar__label"><%= point.label %></span>
            </div>
          <% end %>
        </div>
      </div>

      <div class="surface-panel surface-panel--soft">
        <span class="eyebrow">Telegram</span>
        <h2 class="section-title" style="font-size: clamp(1.45rem, 4vw, 2.1rem); max-width: none;"><%= @telegram_connected ? "Assistant connected" : "Assistant waiting to be linked" %></h2>
        <p class="section-copy">
          <%= @telegram_connected ? "Ayla can already ask for context, request the clip or screenshot, and keep your workflow alive from chat." : "Link Telegram to move prompts, reminders, and capture requests out of your browser and into the place you already check." %>
        </p>
        <% unless @telegram_connected %>
          <%= link_to "Link Telegram", @telegram_connect_url, target: "_blank", rel: "noopener", class: "button-primary" if @telegram_connect_url.present? %>
        <% end %>
      </div>
    </div>
  </section>
</div>
