<div class="page-shell">
  <section class="page-hero">
    <div class="surface-panel surface-panel--accent page-hero__content rise-in">
      <span class="eyebrow">Presence dashboard</span>
      <h1 class="page-title">Stay consistent without turning content into another job.</h1>
      <p class="section-copy section-copy--lead">
        Ayla keeps your presence tied to real work, real moments, and real follow-through. Less pressure. More continuity.
      </p>
    </div>

    <div class="surface-panel page-hero__aside rise-in" style="animation-delay: 100ms;">
      <span class="eyebrow">Current rhythm</span>
      <p class="section-copy">
        <strong><%= @telegram_connected ? "Telegram is linked." : "Telegram is still disconnected." %></strong>
        <%= @telegram_connected ? "Ayla can already nudge you, collect context, and move moments into drafts." : "Link it to start the chat-based workflow that keeps your content moving." %>
      </p>
      <% unless current_user.onboarded? %>
        <%= link_to "Finish onboarding", onboarding_path, class: "button-secondary" %>
      <% end %>
    </div>
  </section>

  <section class="metrics-grid rise-in" style="animation-delay: 160ms;">
    <article class="metric-card">
      <span class="metric-card__label">Pending approval</span>
      <h2 class="metric-card__value"><%= @pending_count %></h2>
      <p class="metric-card__hint">Drafts waiting for your yes before they become part of your public rhythm.</p>
    </article>

    <article class="metric-card">
      <span class="metric-card__label">Approved</span>
      <h2 class="metric-card__value"><%= @approved_count %></h2>
      <p class="metric-card__hint">Pieces already shaped from real moments you decided were worth sharing.</p>
    </article>

    <article class="metric-card">
      <span class="metric-card__label">Telegram</span>
      <h2 class="metric-card__value"><%= @telegram_connected ? "Live" : "Offline" %></h2>
      <p class="metric-card__hint"><%= @telegram_connected ? "Ayla can follow up, ask for context, and keep your cadence warm." : "Connect Telegram to let Ayla prompt you when moments are fresh." %></p>
    </article>
  </section>

  <section class="dashboard-layout">
    <div class="stack">
      <div class="surface-panel">
        <div class="section-header">
          <span class="eyebrow">Recent drafts</span>
          <div class="flex items-end justify-between gap-4 flex-wrap">
            <h2 class="section-title" style="font-size: clamp(1.6rem, 4vw, 2.4rem); max-width: none;">Captured moments, turned into something usable.</h2>
            <%= link_to "View all drafts", content_drafts_path, class: "button-ghost button-ghost--sm" %>
          </div>
        </div>

        <% if @recent_drafts.any? %>
          <div class="timeline-list">
            <% @recent_drafts.each do |draft| %>
              <%= link_to content_draft_path(draft), class: "list-card" do %>
                <div class="list-card__meta">
                  <span><%= time_ago_in_words(draft.created_at) %> ago</span>
                  <span class="<%= draft_status_badge_class(draft.status) %>"><%= draft.status.titleize %></span>
                </div>
                <h3 class="list-card__title"><%= truncate(draft.body, length: 140) %></h3>
                <p class="section-copy">Built from moments you already lived, not from a blank prompt.</p>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <div class="empty-card">
            <h3 class="list-card__title">No drafts yet.</h3>
            <p>Start a Telegram conversation with Ayla and let one real moment become your first approved draft.</p>
          </div>
        <% end %>
      </div>
    </div>

    <div class="stack">
      <% unless @telegram_connected %>
        <div class="surface-panel surface-panel--accent">
          <span class="eyebrow">Connect the assistant</span>
          <h2 class="section-title" style="font-size: clamp(1.5rem, 4vw, 2.2rem); max-width: none;">Ayla works best when it can catch you in the moment.</h2>
          <p class="section-copy">
            <%= @telegram_connect_url.present? ? "Open @#{@telegram_bot_username} and tap Start. From there Ayla can remind you, ask for the clip or context, and keep your weekly presence from slipping." : "Set TELEGRAM_BOT_USERNAME so the one-tap Telegram connect flow can appear here." %>
          </p>
          <% if @telegram_connect_url.present? %>
            <%= link_to "Connect Telegram", @telegram_connect_url, target: "_blank", rel: "noopener", class: "button-primary" %>
          <% end %>
        </div>
      <% end %>

      <div class="surface-panel surface-panel--soft">
        <span class="eyebrow">The Ayla loop</span>
        <div class="stack">
          <div class="mini-panel">
            <span class="mini-panel__label">1. Prompt</span>
            <strong class="mini-panel__title">Ayla notices it is time.</strong>
            <p>It nudges you before a launch, after a client win, or when your posting rhythm starts to drift.</p>
          </div>

          <div class="mini-panel">
            <span class="mini-panel__label">2. Capture</span>
            <strong class="mini-panel__title">You send the real material.</strong>
            <p>A screenshot, a photo, a video, a voice note, or quick context from what actually happened.</p>
          </div>

          <div class="mini-panel">
            <span class="mini-panel__label">3. Draft</span>
            <strong class="mini-panel__title">Ayla turns it into presence.</strong>
            <p>It organizes the moment, asks what is missing, and gives you drafts that still sound like you.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>
