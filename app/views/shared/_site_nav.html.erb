<header class="site-nav">
  <div class="shell shell--wide">
    <div class="site-nav__inner">
      <%= link_to(ayla_signed_in? ? dashboard_path : root_path, { class: "brand-mark" }) do %>
        <span class="brand-mark__signal"></span>
        <span>
          <span class="brand-mark__title">AYLA</span>
          <span class="brand-mark__tag">your personal media manager</span>
        </span>
      <% end %>

      <% if ayla_signed_in? %>
        <% telegram_menu_url = telegram_connect_url_for(current_user) %>
        <% telegram_menu_path = current_user.telegram_connected? ? settings_path(anchor: "assistant-channel") : (telegram_menu_url.presence || settings_path(anchor: "assistant-channel")) %>
        <% telegram_menu_external = !current_user.telegram_connected? && telegram_menu_url.present? %>

        <nav class="site-nav__links">
          <%= link_to "Dashboard", dashboard_path, class: nav_link_classes(dashboard_path, starts_with: "/dashboard") %>
          <%= link_to "Strategy", strategy_path, class: nav_link_classes(strategy_path, starts_with: "/strategy") %>
          <%= link_to "Planification", planification_path, class: nav_link_classes(planification_path, starts_with: "/planification") %>
          <%= link_to "Calendar", calendar_path, class: nav_link_classes(calendar_path, starts_with: "/calendar") %>
        </nav>

        <div class="site-nav__actions">
          <details class="user-menu">
            <summary class="user-menu__summary">
              <span class="nav-presence__dot <%= current_user.telegram_connected? ? 'nav-presence__dot--live' : '' %>"></span>
              <span class="user-menu__identity">
                <strong><%= current_user.name %></strong>
                <span><%= current_user.telegram_connected? ? "Telegram linked" : "Assistant needs linking" %></span>
              </span>
              <span class="user-menu__chevron">▾</span>
            </summary>

            <div class="user-menu__panel">
              <%= link_to "Strategy", strategy_path, class: "user-menu__item" %>
              <%= link_to "Planification", planification_path, class: "user-menu__item" %>
              <%= link_to "Configuration", settings_path, class: "user-menu__item" %>
              <%= link_to "Link Telegram", telegram_menu_path,
                  class: "user-menu__item",
                  target: (telegram_menu_external ? "_blank" : nil),
                  rel: (telegram_menu_external ? "noopener" : nil) %>
              <%= button_to "Sign out", destroy_user_session_path,
                  method: :delete,
                  form_class: "user-menu__form",
                  class: "user-menu__item user-menu__item--danger user-menu__submit" %>
            </div>
          </details>
        </div>
      <% else %>
        <nav class="site-nav__links">
          <%= link_to "How it works", root_path(anchor: "how-it-works"), class: nav_link_classes(root_path(anchor: "how-it-works")) %>
          <%= link_to "Why it's different", root_path(anchor: "difference"), class: nav_link_classes(root_path(anchor: "difference")) %>
          <%= link_to "Who it's for", root_path(anchor: "audience"), class: nav_link_classes(root_path(anchor: "audience")) %>
        </nav>

        <div class="site-nav__actions">
          <%= link_to "Sign in", new_user_session_path, class: "button-ghost button-ghost--sm" %>
          <%= link_to "Get started", new_user_registration_path, class: "button-primary button-primary--sm" %>
        </div>
      <% end %>
    </div>
  </div>
</header>
