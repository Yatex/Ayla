# Database
DATABASE_URL=postgres://localhost:5432/ayla_development

# Redis / Sidekiq
# Use a Redis DB dedicated to Ayla so local Sidekiq queues do not mix with other apps.
SIDEKIQ_REDIS_URL=redis://localhost:6379/1

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_USERNAME=your_bot_username_without_at
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret_here

# AI (placeholder for LLM integration)
OPENAI_API_KEY=your_openai_key_here

# Rails
RAILS_ENV=development
SECRET_KEY_BASE=generate_with_rails_secret
